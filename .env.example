# Server-only secret used for admin login
ADMIN_PASSWORD=123

# Server-only secret used for the admin session cookie
ADMIN_TOKEN=change-this-random-token

# Public site URL used by the frontend
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Required on Vercel if admin edits, enquiries, or image uploads should persist
BLOB_READ_WRITE_TOKEN=

# Optional social profile URLs for structured SEO data
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
